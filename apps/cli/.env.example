# TURN credentials for the CLI host peer.
#
# Optional. Without these, WebRTC uses STUN only — fine for most networks,
# but strict/symmetric NATs may fail to connect. Set them to add a TURN
# relay fallback.
#
# Free option to try: create an account at https://www.metered.ca and use
# the credentials from your dashboard. The CLI's TURN endpoint hosts default
# to metered.ca's global relay; point them elsewhere only for self-hosted
# coturn (see packages/protocol buildIceServers()).
#
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

TURN_USERNAME=
TURN_CREDENTIAL=
